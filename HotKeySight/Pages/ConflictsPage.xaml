<Page
    x:Class="HotKeySight.Pages.ConflictsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部说明 -->
        <Border
            Grid.Row="0"
            Background="{ThemeResource CardFillColorDefaultBrush}"
            CornerRadius="8"
            Padding="20"
            Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <SymbolIcon
                        Symbol="Warning"
                        FontSize="24"
                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                        Margin="0,0,12,0" />
                    <TextBlock
                        Text="热键冲突"
                        FontSize="20"
                        FontWeight="Bold"
                        VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock
                    Text="以下热键被多个应用同时注册，可能导致冲突"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- 冲突列表 -->
        <Border
            Grid.Row="1"
            Background="{ThemeResource CardFillColorDefaultBrush}"
            CornerRadius="8"
            Padding="16">
            <Grid>
                <ListView
                    x:Name="ConflictsListView">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Background="{ThemeResource CardFillColorSecondaryBrush}"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- 热键 -->
                                    <Border
                                        Grid.Row="0"
                                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                        CornerRadius="6"
                                        Padding="16,8"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,12">
                                        <TextBlock
                                            Text="{Binding HotkeyText}"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </Border>

                                    <!-- 注册该热键的应用列表 -->
                                    <ItemsControl
                                        Grid.Row="1"
                                        ItemsSource="{Binding Apps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Background="{ThemeResource CardFillColorDefaultBrush}"
                                                    CornerRadius="4"
                                                    Padding="10,8"
                                                    Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image
                                                            Width="20"
                                                            Height="20"
                                                            Source="{Binding Icon}"
                                                            Margin="0,0,8,0" />
                                                        <TextBlock
                                                            Text="{Binding AppName}"
                                                            FontSize="13" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 无冲突状态 -->
                <StackPanel
                    x:Name="NoConflictsState"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
                    <SymbolIcon
                        Symbol="Checkmark"
                        FontSize="48"
                        Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock
                        Text="没有发现热键冲突"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
